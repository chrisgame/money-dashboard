<div ...attributes {{line-chart this.dimentions @data this.options}}></div>
<svg
  ...attributes
  {{dimentions width=@width height=@height}}
  {{x-axis
    data=@data
    height=this.xAxis.height
    rangeStart=this.xAxis.rangeStart
    rangeEnd=this.xAxis.rangeEnd
    x=this.x
  }}
  {{y-axis
    data=@data
    width=this.yAxis.width
    rangeStart=this.yAxis.rangeStart
    rangeEnd=this.yAxis.rangeEnd
    formatTickLabel=this.yAxis.formatTickLabel
    y=this.y
  }}
  {{paths
    data=@data
    x=this.x
    y=this.y
    color=this.options.color
  }}
  {{legend
    data=@data
    dimentions=this.dimentions
    formatLabel=this.options.formatLegendLabel
    color=this.options.color
  }}
>
</svg>
